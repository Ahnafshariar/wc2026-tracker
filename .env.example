# Copy to .env and adjust.  NEVER commit .env  (it is gitignored).

# Live data source (default = worldcup26, keyless, no setup needed):
#   worldcup26  | footballdata (+key) | espn | demo | static
DATA_SOURCE=worldcup26

# worldcup26.ir base (override only if self-hosting the API or it moves)
WC26_BASE=https://worldcup26.ir
# WC26_TOKEN=                 # only if the host ever requires auth

# football-data.org key (only if DATA_SOURCE=footballdata)
# FOOTBALL_API_KEY=

PORT=3000
REFRESH_INTERVAL=30000        # how often to poll the live API (ms)
SIM_INTERVAL=4000             # demo tick interval (ms), only for DATA_SOURCE=demo
